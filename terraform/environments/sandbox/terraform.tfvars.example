# Copy this file to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it is in .gitignore.

project      = "maia-landing-zone"
aws_region   = "us-east-1"

approved_regions = ["eu-west-1", "eu-west-3", "us-east-1"]

# Management account ID (12-digit number)
management_account_id  = "123456789012"
audit_account_id       = "234567890123"
log_archive_account_id = "345678901234"

# IAM Identity Center group IDs — find in the Identity Center console
# after creating the groups manually or via SCIM
platform_team_group_id = "your-platform-team-group-id"
developers_group_id    = "your-developers-group-id"
security_team_group_id = "your-security-team-group-id"
finops_group_id        = "your-finops-group-id"